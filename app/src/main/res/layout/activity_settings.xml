<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nabd_deep_navy"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:layoutDirection="ltr"
    android:scrollbarStyle="outsideOverlay">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:layoutDirection="ltr"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="18dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:orientation="vertical"
            android:paddingHorizontal="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="@color/nabd_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Privacy, performance, search, and local data."
                android:textColor="@color/nabd_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_nabd_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Protection"
                android:textColor="@color/nabd_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_speed_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Current: BALANCED"
                android:textColor="@color/nabd_text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_speed_off"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/nabd_deep_navy"
                    android:text="OFF"
                    android:textAllCaps="false"
                    android:textColor="@color/nabd_text_primary"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/nabd_border"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_speed_balanced"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginHorizontal="3dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/nabd_deep_navy"
                    android:text="Balanced"
                    android:textAllCaps="false"
                    android:textColor="@color/nabd_text_primary"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/nabd_border"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_speed_extreme"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/nabd_deep_navy"
                    android:text="Extreme"
                    android:textAllCaps="false"
                    android:textColor="@color/nabd_text_primary"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/nabd_border"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="14dp"
                android:background="@color/nabd_border" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Security insights"
                        android:textColor="@color/nabd_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Review blocked requests and protection stats."
                        android:textColor="@color/nabd_text_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="124dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_protection_stats"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:backgroundTint="@color/nabd_text_primary"
                        android:text="Stats"
                        android:textAllCaps="false"
                        android:textColor="@color/surface"
                        android:textSize="12sp"
                        app:cornerRadius="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_adblock_debug"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginTop="6dp"
                        android:backgroundTint="@color/nabd_deep_navy"
                        android:text="Debug"
                        android:textAllCaps="false"
                        android:textColor="@color/nabd_text_primary"
                        android:textSize="12sp"
                        app:cornerRadius="8dp"
                        app:strokeColor="@color/nabd_border"
                        app:strokeWidth="1dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_nabd_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lite_mode_title"
                    android:textColor="@color/nabd_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/lite_mode_description"
                    android:textColor="@color/nabd_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_lite_mode"
                android:layout_width="156dp"
                android:layout_height="48dp"
                android:backgroundTint="@color/nabd_text_primary"
                android:text="@string/lite_mode_off"
                android:textAllCaps="false"
                android:textColor="@color/surface"
                android:textSize="12sp"
                app:cornerRadius="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_nabd_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Privacy and data"
                android:textColor="@color/nabd_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_allowlist_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="0 sites allowlisted"
                android:textColor="@color/nabd_text_secondary"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_clear_allowlist"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/nabd_deep_navy"
                android:text="Clear allowlisted sites"
                android:textAllCaps="false"
                android:textColor="@color/nabd_text_primary"
                android:textSize="12sp"
                app:cornerRadius="8dp"
                app:strokeColor="@color/nabd_border"
                app:strokeWidth="1dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="14dp"
                android:background="@color/nabd_border" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cookie_banner"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:backgroundTint="@color/nabd_text_primary"
                android:text="Cookie Banner Control: Enabled"
                android:textAllCaps="false"
                android:textColor="@color/surface"
                android:textSize="12sp"
                app:cornerRadius="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_history"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/nabd_deep_navy"
                    android:text="History"
                    android:textAllCaps="false"
                    android:textColor="@color/nabd_text_primary"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/nabd_border"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_cookies"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/nabd_deep_navy"
                    android:text="Cookies"
                    android:textAllCaps="false"
                    android:textColor="@color/nabd_text_primary"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/nabd_border"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_cache"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/nabd_deep_navy"
                    android:text="Cache"
                    android:textAllCaps="false"
                    android:textColor="@color/nabd_text_primary"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/nabd_border"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_all"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/nabd_text_primary"
                    android:text="Clear all"
                    android:textAllCaps="false"
                    android:textColor="@color/surface"
                    android:textSize="12sp"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_nabd_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txt_zero_tracking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Zero Tracking Mode: Enabled"
                android:textColor="@color/nabd_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="3dp"
                android:text="Third-party cookies: Blocked\nMixed content: Blocked\nFile access: Disabled\nGeolocation: Disabled\nHTTPS-Only Mode: Enabled\nSuspicious domain warning: Enabled\nDNT / GPC headers: Sent\nApp telemetry: Off\nTracking SDKs: None"
                android:textColor="@color/nabd_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_nabd_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search engine"
                android:textColor="@color/nabd_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_search_engine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Current: DuckDuckGo"
                android:textColor="@color/nabd_text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_search_duckduckgo"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/nabd_deep_navy"
                    android:text="DuckDuckGo"
                    android:textAllCaps="false"
                    android:textColor="@color/nabd_text_primary"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/nabd_border"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_search_brave"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/nabd_deep_navy"
                    android:text="Brave"
                    android:textAllCaps="false"
                    android:textColor="@color/nabd_text_primary"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/nabd_border"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_search_startpage"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/nabd_deep_navy"
                    android:text="Startpage"
                    android:textAllCaps="false"
                    android:textColor="@color/nabd_text_primary"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/nabd_border"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_search_google"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/nabd_deep_navy"
                    android:text="Google"
                    android:textAllCaps="false"
                    android:textColor="@color/nabd_text_primary"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/nabd_border"
                    app:strokeWidth="1dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_nabd_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Browser"
                android:textColor="@color/nabd_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Start Page: New Tab Page"
                android:textColor="@color/nabd_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/downloads_location"
                android:textColor="@color/nabd_text_muted"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_downloads"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/nabd_deep_navy"
                    android:text="@string/downloads_label"
                    android:textAllCaps="false"
                    android:textColor="@color/nabd_text_primary"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/nabd_border"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_about"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/nabd_deep_navy"
                    android:text="About"
                    android:textAllCaps="false"
                    android:textColor="@color/nabd_text_primary"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/nabd_border"
                    app:strokeWidth="1dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
