<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings"
        android:textSize="24sp"
        android:textStyle="bold"
        android:paddingBottom="24dp"
        android:textColor="@color/black" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/adblockSwitch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/enable_adblock"
        android:textSize="18sp"
        android:padding="8dp" />

    <TextView
        android:id="@+id/rulesCountText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/rules_loaded"
        android:textSize="14sp"
        android:padding="8dp"
        android:textColor="@android:color/darker_gray" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginVertical="16dp" />

    <Button
        android:id="@+id/cleanAdsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/clean_ads"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/resetCounterButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/reset_counter"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

</LinearLayout>
