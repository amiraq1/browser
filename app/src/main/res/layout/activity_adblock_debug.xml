<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/nabd_deep_navy">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_top_bar"
        android:elevation="2dp"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/adblock_debug"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/nabd_pulse_cyan"
            android:letterSpacing="0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="فحص قواعد الحظر"
            android:textSize="12sp"
            android:textColor="@color/nabd_teal"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Scroll content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbarStyle="outsideOverlay">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp"
            android:clipToPadding="false">

            <!-- ============== Stats card ============== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_nabd_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stats"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/nabd_pulse_cyan"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/debug_stats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#A7B6CC"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

            <!-- ============== Recent blocked card ============== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_nabd_card"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recent_blocked"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/nabd_pulse_cyan"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:id="@+id/blocked_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
