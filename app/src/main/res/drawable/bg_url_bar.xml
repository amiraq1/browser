<?xml version="1.0" encoding="utf-8"?>
<!--
    URL bar background — Nabd brand: Slate fill with a hairline border
    that brightens to Pulse Cyan when the EditText is focused. Drawable
    only; no IDs, no behavior, no padding changes that would alter the
    EditText's text alignment.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused state: bright cyan ring -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/nabd_slate" />
            <stroke android:width="1.5dp" android:color="@color/nabd_pulse_cyan" />
            <corners android:radius="14dp" />
            <padding android:left="10dp" android:right="10dp" />
        </shape>
    </item>

    <!-- Default state: subtle dark border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/nabd_slate" />
            <stroke android:width="1dp" android:color="#1F2A3E" />
            <corners android:radius="14dp" />
            <padding android:left="10dp" android:right="10dp" />
        </shape>
    </item>

</selector>
