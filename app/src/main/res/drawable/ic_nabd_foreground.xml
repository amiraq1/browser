<?xml version="1.0" encoding="utf-8"?>
<!--
    Nabd Browser foreground icon.
    ViewBox is 108x108 dp (Android adaptive-icon spec).
    All visible elements are kept inside the central 66x66 safe zone
    (bounds 21,21 → 87,87) so they survive any system mask shape.

    Visual elements:
      * Shield  — slate fill with teal stroke (privacy/protection)
      * Pulse   — cyan heartbeat line across the shield (نبض)
      * Dot     — neon green endpoint of the pulse (the "beat")
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Shield body -->
    <path
        android:pathData="M54,32 L76,40 L76,56 C76,70 66,78 54,82 C42,78 32,70 32,56 L32,40 Z"
        android:fillColor="#FFFFFF"
        android:strokeColor="#111827"
        android:strokeWidth="2.5"
        android:strokeLineJoin="round" />

    <!-- Heartbeat / pulse line -->
    <path
        android:pathData="M36,58 L42,58 L45,52 L48,66 L52,48 L56,66 L60,54 L64,58 L72,58"
        android:strokeColor="#4B5563"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000" />

    <!-- Pulse endpoint dot (the "Nabd" beat) -->
    <path
        android:pathData="M72,58 m-2.5,0 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0"
        android:fillColor="#111827" />

</vector>
