<?xml version="1.0" encoding="utf-8"?>
<!--
    Nabd brand "card" surface — used for Settings sections and similar
    privacy-panel containers. Slate fill, subtle teal hairline border,
    soft 12dp corners. Background-only resource; safe to reuse.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/nabd_slate" />
    <corners android:radius="12dp" />
    <stroke
        android:width="1dp"
        android:color="#1F2A3E" />
</shape>
