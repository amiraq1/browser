<?xml version="1.0" encoding="utf-8"?>
<!--
    Browser progress bar drawable — cyan progress on a thin dark navy
    track. Two layer ids matter: @android:id/background and
    @android:id/progress (clip), so the system ProgressBar can animate
    the progress portion correctly.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <solid android:color="@color/nabd_border" />
        </shape>
    </item>

    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <solid android:color="@color/nabd_pulse_cyan" />
            </shape>
        </clip>
    </item>

</layer-list>
