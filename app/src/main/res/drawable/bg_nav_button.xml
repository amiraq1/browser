<?xml version="1.0" encoding="utf-8"?>
<!--
    Nav-button ripple — circular cyan-tinted ripple for the bottom
    toolbar ImageButtons (back / forward / refresh / menu). Visible on
    Deep Navy background where the default light-theme ripple is too
    subtle. Drawable-only; no IDs, no behavior.
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/nabd_pressed">
    <item android:id="@android:id/mask">
        <shape android:shape="oval">
            <solid android:color="@color/surface" />
        </shape>
    </item>
</ripple>
