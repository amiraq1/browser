<?xml version="1.0" encoding="utf-8"?>
<!--
    Tab counter pill — Nabd brand: rounded transparent pill with a
    cyan hairline border. The number inside is colored cyan via the
    layout's android:textColor. Drawable-only.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <stroke android:width="1.5dp" android:color="@color/nabd_pulse_cyan" />
    <corners android:radius="6dp" />
    <solid android:color="@color/surface" />
</shape>
